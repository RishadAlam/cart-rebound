{
	"name": "cart-rebound",
	"version": "0.2.0",
	"description": "Tracks abandoned WooCommerce carts and helps recover them with email reminders and secure recovery links.",
	"license": "GPL-2.0-or-later",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.5.0",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"clean": "rm -rf node_modules .pnpm-store",
		"fresh-install": "pnpm run clean && pnpm install --frozen-lockfile",
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"ts-check": "tsc --noEmit",
		"pretty": "prettier --check \"resources/**/*.{ts,tsx,css,scss,json}\" \".wordpress-org/**/*.json\"",
		"pretty:fix": "prettier --write \"resources/**/*.{ts,tsx,css,scss,json}\" \".wordpress-org/**/*.json\"",
		"lint": "eslint resources/js --max-warnings=0",
		"lint:fix": "eslint resources/js --fix",
		"stylelint": "stylelint \"resources/**/*.{css,scss}\"",
		"stylelint:fix": "stylelint \"resources/**/*.{css,scss}\" --fix",
		"qa": "run-s ts-check pretty lint stylelint",
		"qa:all": "run-s qa qa:php",
		"qa:php": "composer qa",
		"build-zip": "bash scripts/build-zip.sh",
		"production-zip": "run-s qa:all build-zip",
		"prepare": "husky"
	},
	"dependencies": {
		"@tanstack/react-query": "^5.59.0",
		"@wordpress/i18n": "^6.24.0",
		"axios": "^1.7.7",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-router-dom": "^6.27.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.5.0",
		"@commitlint/config-conventional": "^19.5.0",
		"@types/node": "^20.16.11",
		"@types/react": "^18.3.11",
		"@types/react-dom": "^18.3.1",
		"@typescript-eslint/eslint-plugin": "^8.8.1",
		"@typescript-eslint/parser": "^8.8.1",
		"@vitejs/plugin-react": "^4.3.2",
		"@wordpress/eslint-plugin": "^21.5.0",
		"@wordpress/prettier-config": "^4.10.0",
		"@wordpress/stylelint-config": "^23.4.0",
		"autoprefixer": "^10.4.20",
		"eslint": "^8.57.1",
		"eslint-plugin-react": "^7.37.1",
		"eslint-plugin-react-hooks": "^4.6.2",
		"husky": "^9.1.6",
		"lint-staged": "^15.2.10",
		"npm-run-all2": "^6.2.3",
		"postcss": "^8.4.47",
		"prettier": "^3.3.3",
		"stylelint": "^16.9.0",
		"tailwindcss": "^3.4.13",
		"terser": "^5.49.0",
		"typescript": "^5.6.3",
		"vite": "^6.4.2"
	}
}
